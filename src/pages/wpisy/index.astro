---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BentoPostsGrid from "../../components/BentoPostsGrid.astro";
import { posts } from "../../data/posts";

const [featuredPost, ...remainingPosts] = posts;
---

<BaseLayout
  title="Blog Biblijny | Wpisy"
  description="Wyróżniony wpis i siatka artykułów o Mojżeszu."
>
  <section class="posts-page">
    <a class="featured-link" href={`/wpisy/${featuredPost.slug}/`}>
      <article class="surface featured-card">
        <div class="featured-meta">
          <span class="featured-pill">Wpis wyróżniony</span>
          <span class="featured-date">{featuredPost.date}</span>
        </div>
        <h1>{featuredPost.title}</h1>
        <p>{featuredPost.excerpt}</p>
        <span class="read-more">Czytaj dalej</span>
      </article>
    </a>

    <BentoPostsGrid title="Pozostałe wpisy" posts={remainingPosts} />
  </section>
</BaseLayout>

<style>
  .posts-page {
    display: grid;
    gap: 1.6rem;
  }

  .featured-link {
    display: block;
  }

  .featured-card {
    border-radius: 30px;
    border: 1px solid rgba(129, 199, 132, 0.34);
    background:
      linear-gradient(140deg, rgba(129, 199, 132, 0.34), rgba(241, 248, 233, 0.78), #ffffff),
      repeating-linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.14) 0 12px,
        rgba(241, 248, 233, 0.12) 12px 24px
      );
    box-shadow: 0 22px 42px rgba(86, 120, 80, 0.16);
    padding: clamp(1.6rem, 4vw, 2.8rem);
    display: grid;
    gap: 1rem;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 48px rgba(86, 120, 80, 0.2);
  }

  .featured-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .featured-pill {
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    background: #1b5e20;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .featured-date {
    color: #557062;
    font-size: 0.9rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    font-family: "Geist", "Inter", sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #203025;
    max-width: 18ch;
  }

  p {
    margin: 0;
    max-width: 65ch;
    color: #405649;
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .read-more {
    width: fit-content;
    border-radius: 999px;
    border: 1px solid rgba(27, 94, 32, 0.16);
    background: rgba(255, 255, 255, 0.86);
    color: #1b5e20;
    font-size: 0.92rem;
    font-weight: 800;
    padding: 0.58rem 0.95rem;
  }
</style>
