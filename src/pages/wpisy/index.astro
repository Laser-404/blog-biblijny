---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BentoPostsGrid from "../../components/BentoPostsGrid.astro";
import { posts } from "../../data/posts";

const [featuredPost, ...remainingPosts] = posts;
---

<BaseLayout
  title="Blog Biblijny | Wpisy"
  description="Wyróżniony wpis i siatka artykułów o Mojżeszu."
>
  <section class="posts-page">
    <header class="surface posts-intro">
      <h1 class="posts-title">Poznaj historię Mojżesza: Od Nilu do Ziemi Obiecanej.</h1>
    </header>

    <a class="featured-link" href={`/wpisy/${featuredPost.slug}/`}>
      <article class="surface featured-card">
        <div class="featured-meta">
          <span class="featured-pill">Wpis wyróżniony</span>
          <span class="featured-date">{featuredPost.date}</span>
        </div>
        <h1>{featuredPost.title}</h1>
        <p>{featuredPost.excerpt}</p>
        <span class="read-more">Czytaj dalej</span>
      </article>
    </a>

    <BentoPostsGrid title="Pozostałe wpisy" posts={remainingPosts} />
  </section>
</BaseLayout>

<style>
  .posts-page {
    display: grid;
    gap: 1.8rem;
  }

  .posts-intro {
    padding: clamp(1.3rem, 2.4vw, 1.9rem);
  }

  .posts-title {
    margin: 0;
    font-family: "Geist", "Inter", sans-serif;
    font-size: clamp(1.7rem, 3.6vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: #1f2b22;
    max-width: 24ch;
  }

  .featured-link {
    display: block;
  }

  .featured-card {
    padding: clamp(1.7rem, 4vw, 2.8rem);
    display: grid;
    gap: 1rem;
  }

  .featured-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .featured-pill {
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    background: #1b5e20;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .featured-date {
    color: #557062;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .featured-card h1 {
    margin: 0;
    font-family: "Geist", "Inter", sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #203025;
    max-width: 18ch;
  }

  p {
    margin: 0;
    max-width: 65ch;
    color: #405649;
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .read-more {
    width: fit-content;
    border-radius: 999px;
    border: 1px solid rgba(27, 94, 32, 0.16);
    background: rgba(255, 255, 255, 0.88);
    color: #1b5e20;
    font-size: 0.92rem;
    font-weight: 800;
    padding: 0.58rem 0.95rem;
  }
</style>
