---
import BaseLayout from "../../layouts/BaseLayout.astro";

const wyróżniony = {
  tytuł: "Mojżesz: Prorok i Wyzwoliciel",
  opis:
    "Najważniejszy wpis serii przedstawia Mojżesza jako człowieka powołanego do przeprowadzenia ludu Izraela przez drogę od niewoli do wolności. Artykuł łączy kontekst historyczny z refleksją duchową i analizą przywództwa.",
  data: "23 lutego 2026",
};

const wpisy = [
  {
    tytuł: "Powołanie przy krzewie gorejącym",
    opis: "Rozmowa Mojżesza z Bogiem i znaczenie imienia " + '"JESTEM"' + " dla misji wyzwolenia.",
    data: "12 lutego 2026",
    kategoria: "Historia",
  },
  {
    tytuł: "Dziesięć plag i upadek pychy faraona",
    opis: "Jak narracja o plagach odsłania zderzenie ludzkiej władzy z wolą Boga.",
    data: "15 lutego 2026",
    kategoria: "Analiza",
  },
  {
    tytuł: "Przejście przez Morze Czerwone",
    opis: "Wydarzenie graniczne: koniec niewoli i początek nowego etapu życia wspólnoty.",
    data: "17 lutego 2026",
    kategoria: "Egzegeza",
  },
  {
    tytuł: "Dekalog jako fundament ładu",
    opis: "Dziesięć przykazań jako praktyczny porządek relacji człowieka z Bogiem i drugim człowiekiem.",
    data: "20 lutego 2026",
    kategoria: "Refleksja",
  },
  {
    tytuł: "Manna i zaufanie na pustyni",
    opis: "Codzienne doświadczenie zależności od Boga i lekcja cierpliwości dla całego ludu.",
    data: "22 lutego 2026",
    kategoria: "Duchowość",
  },
  {
    tytuł: "Mojżesz jako mediator",
    opis: "Rola Mojżesza w rozwiązywaniu konfliktów i prowadzeniu ludzi przez kryzysy.",
    data: "23 lutego 2026",
    kategoria: "Przywództwo",
  },
];
---

<BaseLayout title="Blog Biblijny | Wpisy" description="Wpisy o Mojżeszu: wyróżniony artykuł i lista pozostałych materiałów.">
  <section class="surface hero-wpis">
    <p class="hero-chip">Wyróżnione</p>
    <h1>{wyróżniony.tytuł}</h1>
    <p>{wyróżniony.opis}</p>
    <p class="hero-meta">Data publikacji: {wyróżniony.data}</p>
  </section>

  <section class="lista-wpisow" aria-labelledby="lista-tytul">
    <div class="list-head">
      <h2 id="lista-tytul">Pozostałe wpisy</h2>
      <a href="/">Powrót na stronę główną</a>
    </div>

    <div class="posts-grid" role="list">
      {
        wpisy.map((wpis) => (
          <article class="post-card" role="listitem">
            <p class="post-tag">{wpis.kategoria}</p>
            <h3>{wpis.tytuł}</h3>
            <p>{wpis.opis}</p>
            <p class="post-date">{wpis.data}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero-wpis,
  .post-card {
    border-radius: 24px;
    border: 1px solid rgba(129, 199, 132, 0.38);
    background: #ffffff;
    box-shadow: 0 16px 34px rgba(129, 199, 132, 0.14);
  }

  .hero-wpis {
    padding: clamp(1.5rem, 3.2vw, 2.8rem);
    background: linear-gradient(150deg, rgba(129, 199, 132, 0.2), rgba(255, 255, 255, 0.98));
  }

  .hero-chip {
    margin: 0;
    width: fit-content;
    border-radius: 999px;
    border: 1px solid rgba(129, 199, 132, 0.52);
    padding: 0.32rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #3d5b49;
    background: rgba(255, 255, 255, 0.82);
  }

  h1,
  h2,
  h3 {
    margin: 0;
    line-height: 1.2;
    font-family: "Geist", "Inter", sans-serif;
    letter-spacing: -0.01em;
  }

  h1 {
    margin-top: 0.75rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  h2 {
    font-size: clamp(1.45rem, 2.4vw, 2rem);
  }

  h3 {
    font-size: 1.18rem;
  }

  p {
    margin: 0.8rem 0 0;
    color: #4e6356;
    line-height: 1.85;
  }

  .hero-meta {
    margin-top: 1rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: #3f5d4b;
  }

  .lista-wpisow {
    margin-top: 1rem;
  }

  .list-head {
    margin-bottom: 0.9rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .list-head a {
    border-radius: 999px;
    border: 1px solid rgba(129, 199, 132, 0.45);
    padding: 0.4rem 0.78rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #3f5d4b;
    background: rgba(255, 255, 255, 0.8);
  }

  .posts-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .post-card {
    padding: 1.15rem;
  }

  .post-tag {
    margin: 0;
    width: fit-content;
    border-radius: 999px;
    border: 1px solid rgba(129, 199, 132, 0.46);
    padding: 0.24rem 0.68rem;
    font-size: 0.79rem;
    font-weight: 700;
    color: #446255;
    background: #f8fcf4;
  }

  .post-date {
    margin-top: 0.9rem;
    font-size: 0.86rem;
    color: #5e7666;
    font-weight: 600;
  }

  @media (min-width: 760px) {
    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .posts-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
