---
const {
  title = "Blog Biblijny",
  description = "Nowoczesny, minimalistyczny blog o Mojżeszu.",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg-soft: #d1dcc9;
        --sage: #81c784;
        --white: #ffffff;
        --ink: #1f2b22;
        --ink-muted: #4e6356;
        --line: #c2cdc1;
        --card-line: #c8d1c5;
        --radius-xl: 32px;
        --radius-pill: 999px;
        --card-shadow:
          inset 0 2px 8px rgba(255, 255, 255, 0.7),
          0 10px 25px rgba(45, 71, 44, 0.08);
        --card-hover-shadow:
          inset 0 2px 8px rgba(255, 255, 255, 0.7),
          0 10px 25px rgba(45, 71, 44, 0.08);
        --card-gradient: linear-gradient(135deg, #ffffff 10%, #e1ebd8 85%);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        color: var(--ink);
        font-family: "Inter", "Geist", "Segoe UI", sans-serif;
        line-height: 1.8;
        background:
          radial-gradient(circle at 92% 8%, rgba(129, 199, 132, 0.22), transparent 38%),
          radial-gradient(circle at 8% 28%, rgba(129, 199, 132, 0.16), transparent 34%),
          linear-gradient(180deg, #dae4d3 0%, var(--bg-soft) 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 40;
        background: rgba(244, 249, 241, 0.85);
        -webkit-backdrop-filter: blur(12px);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(45, 71, 44, 0.08);
      }

      .shell {
        width: min(1120px, calc(100% - 2rem));
        margin-inline: auto;
      }

      .header-row {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        font-family: "Geist", "Inter", sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        color: #1e331a;
      }

      .brand::before {
        content: "";
        display: inline-block;
        width: 0.65rem;
        height: 0.65rem;
        margin-right: 0.6rem;
        border-radius: 50%;
        background: var(--sage);
        box-shadow: 0 0 0 0.35rem rgba(129, 199, 132, 0.24);
      }

      .main-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .main-nav a {
        border-radius: var(--radius-pill);
        padding: 0.55rem 1rem;
        border: 1px solid transparent;
        color: #1e331a;
        font-size: 0.95rem;
        font-weight: 600;
        transition: all 160ms ease;
      }

      .main-nav a:hover {
        color: #1e331a;
        border-color: rgba(129, 199, 132, 0.4);
        background: rgba(255, 255, 255, 0.78);
      }

      main {
        width: min(1120px, calc(100% - 2rem));
        margin-inline: auto;
        padding: 2rem 0 2.75rem;
      }

      .surface {
        background: var(--card-gradient);
        border: 1px solid var(--card-line);
        border-radius: var(--radius-xl);
        box-shadow: var(--card-shadow);
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
      }

      .surface:hover {
        transform: translateY(-8px);
        box-shadow: var(--card-hover-shadow);
      }

      footer {
        margin-top: auto;
      }

      .footer-shell {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto 1.1rem;
        background: rgba(255, 255, 255, 0.74);
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        padding: 1rem 1.15rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        color: var(--ink-muted);
        font-size: 0.92rem;
      }

      @media (max-width: 760px) {
        .header-row {
          min-height: 64px;
          padding-block: 0.5rem;
          align-items: flex-start;
          flex-direction: column;
          justify-content: center;
        }

        .main-nav a {
          padding: 0.5rem 0.85rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="site">
      <header class="site-header">
        <div class="shell header-row">
          <a href="/" class="brand">Blog Biblijny</a>
          <nav class="main-nav" aria-label="Nawigacja główna">
            <a href="/">Strona główna</a>
            <a href="/wpisy/">Wpisy</a>
            <a href="/about/">O projekcie</a>
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        <div class="footer-shell">
          <span>Minimalistyczny blog o postaci Mojżesza</span>
          <span>&copy; {new Date().getFullYear()}</span>
        </div>
      </footer>
    </div>
  </body>
</html>
