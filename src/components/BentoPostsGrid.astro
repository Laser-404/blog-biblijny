---
import { posts as allPosts } from "../data/posts";
import type { Post } from "../data/posts";

const {
  title = "Pozostałe wpisy",
  posts = allPosts.slice(1),
  showHeaderLink = false,
  headerLinkHref = "/wpisy/",
  headerLinkLabel = "Zobacz wszystkie",
} = Astro.props as {
  title?: string;
  posts?: Post[];
  showHeaderLink?: boolean;
  headerLinkHref?: string;
  headerLinkLabel?: string;
};
---

<section class="posts-wrap">
  <div class="posts-head">
    <h2>{title}</h2>
    {
      showHeaderLink && (
        <a href={headerLinkHref} class="head-link">
          {headerLinkLabel}
        </a>
      )
    }
  </div>

  <div class="posts-grid" role="list">
    {
      posts.map((post) => (
        <a class="post-card" role="listitem" href={`/wpisy/${post.slug}/`}>
          <div class="thumb" aria-hidden="true">
            <span>{post.thumbnailLabel}</span>
          </div>
          <div class="meta-row">
            <p class="post-tag">{post.category}</p>
            <time>{post.date}</time>
          </div>
          <h3>{post.title}</h3>
        </a>
      ))
    }
  </div>
</section>

<style>
  .posts-wrap {
    display: grid;
    gap: 1rem;
  }

  .posts-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  h2 {
    margin: 0;
    font-family: "Geist", "Inter", sans-serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    letter-spacing: -0.01em;
    color: #203025;
  }

  .head-link {
    border-radius: 999px;
    border: 1px solid rgba(129, 199, 132, 0.42);
    padding: 0.45rem 0.8rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #3d5b49;
    background: rgba(255, 255, 255, 0.76);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .post-card {
    border-radius: 28px;
    border: 1px solid rgba(129, 199, 132, 0.34);
    background:
      linear-gradient(155deg, rgba(241, 248, 233, 0.72), rgba(255, 255, 255, 0.98)),
      #ffffff;
    box-shadow: 0 16px 32px rgba(88, 121, 82, 0.12);
    padding: 1rem;
    display: grid;
    gap: 0.9rem;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 36px rgba(88, 121, 82, 0.16);
  }

  .thumb {
    min-height: 132px;
    border-radius: 22px;
    border: 1px solid rgba(129, 199, 132, 0.28);
    background:
      linear-gradient(135deg, rgba(129, 199, 132, 0.22), rgba(241, 248, 233, 0.84)),
      repeating-linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.34) 0 8px,
        rgba(241, 248, 233, 0.22) 8px 16px
      );
    display: grid;
    place-items: center;
    color: #50705c;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .post-tag {
    margin: 0;
    border-radius: 999px;
    border: 1px solid rgba(27, 94, 32, 0.14);
    background: #1b5e20;
    color: #ffffff;
    font-size: 0.74rem;
    font-weight: 700;
    padding: 0.28rem 0.62rem;
    line-height: 1.2;
  }

  time {
    color: #607768;
    font-size: 0.84rem;
    font-weight: 600;
  }

  h3 {
    margin: 0;
    font-family: "Geist", "Inter", sans-serif;
    font-size: 1.14rem;
    line-height: 1.35;
    color: #223126;
  }

  @media (min-width: 760px) {
    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .posts-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
